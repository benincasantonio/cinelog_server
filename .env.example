# Server Configuration
# ENVIRONMENT=development
# PORT=8000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/cinelog_db
MONGODB_DB=cinelog_db

# CORS Configuration
# CORS_ORIGINS=https://cinelog.app,https://www.cinelog.app
# Auth Configuration
JWT_SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_SECRET_KEY
RATE_LIMIT_HMAC_SECRET=CHANGE_THIS_IN_PRODUCTION_RATE_LIMIT_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email Configuration
# Email Configuration (Dev: Mailpit)
SMTP_SERVER=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@cinelog.app

# Redis Configuration (required — used for caching and rate limiting)
REDIS_URL=redis://localhost:6379/0
# REDIS_DEFAULT_TTL=300
# STATS_CACHE_TTL=259200

# TMDB Configuration
TMDB_API_KEY=your_tmdb_api_key_here
# TMDB_TIMEOUT=10
# TMDB_SEARCH_CACHE_TTL=600
# TMDB_DETAILS_CACHE_TTL=86400
